# Variáveis de ambiente da aplicação (PRODUÇÃO).
# Copie este arquivo para config/.env.prod e preencha com os valores reais.
# O config/.env.prod NÃO deve ser versionado (já está no .gitignore).

# Connection string lida pela API. O ASP.NET Core mapeia o "__" para a seção:
# ConnectionStrings:DefaultConnection
ConnectionStrings__DefaultConnection=Host=SEU_HOST;Port=5432;Database=gestao_equipamentos;Username=SEU_USUARIO;Password=SUA_SENHA

# Connection string usada pelas migrations (AppDbContextFactory, design-time).
CONNECTION_STRING=Host=SEU_HOST;Port=5432;Database=gestao_equipamentos;Username=SEU_USUARIO;Password=SUA_SENHA
